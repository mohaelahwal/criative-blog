---

<header class="fixed top-0 left-0 right-0 z-50 bg-transparent">
  <div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-center relative">
    <a
      href="/"
      class="text-[11px] font-medium lowercase tracking-[0.3em] text-white/50
             hover:text-white transition-colors duration-300"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      raww.io
    </a>
    <a
      href="http://criative.net"
      target="_blank"
      rel="noopener noreferrer"
      class="absolute right-6 rounded-none bg-white/30 text-white font-medium
             px-5 py-2 text-[11px] tracking-[0.3em] lowercase
             hover:bg-white/50 transition-colors duration-200"
      style="font-family: 'Space Grotesk', sans-serif;"
    >
      Know Me
    </a>
  </div>
</header>

<div class="h-14"></div>
