---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'>;
const post = Astro.props;
const { Content } = await render(post);

const { title, description, pubDate, image, sourceLink, source } = post.data;

const SOURCE_LABELS: Record<string, string> = {
  'awwwards':     'Awwwards',
  'google-cloud': 'Google Cloud',
  'feed':         'From the Feed',
};

const sourceLabel = SOURCE_LABELS[source ?? ''] ?? 'Post';

const date = pubDate.toLocaleDateString('en-US', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
});
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${title} — raww.io`} description={description ?? ''} image={image} />
  </head>

  <body class="bg-[#0a0a0a] text-white min-h-screen">
    <Header />

    <article class="max-w-3xl mx-auto px-6 py-12">

      {/* ── Meta row ──────────────────────────── */}
      <div class="flex items-center gap-3 mb-8">
        <a href="/" class="text-white/25 hover:text-white/60 transition-colors text-xs flex items-center gap-1.5 group">
          <svg class="w-3 h-3 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
          </svg>
          Back
        </a>
        <span class="w-px h-3 bg-white/10"></span>
        <span class="text-[10px] font-medium uppercase tracking-widest text-white/30">{sourceLabel}</span>
        <span class="w-px h-3 bg-white/10"></span>
        <time class="text-[10px] text-white/25">{date}</time>
      </div>

      {/* ── Title ─────────────────────────────── */}
      <h1 class="text-2xl md:text-3xl lg:text-4xl font-bold text-white leading-tight tracking-tight mb-6">
        {title}
      </h1>

      {description && (
        <p class="text-white/45 text-base leading-relaxed mb-8 border-b border-white/[0.07] pb-8">
          {description}
        </p>
      )}

      {/* ── Hero image ────────────────────────── */}
      {image && (
        <div class="rounded-xl overflow-hidden border border-white/[0.08] mb-10">
          <img
            src={image}
            alt={title}
            class="w-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>
      )}

      {/* ── Markdown body ─────────────────────── */}
      <div class="prose-content">
        <Content />
      </div>

      {/* ── Share block ───────────────────────── */}
      {(() => {
        const postUrl    = encodeURIComponent(Astro.url.href);
        const postTitle  = encodeURIComponent(title ?? '');
        return (
          <div class="relative z-50 flex items-center gap-5 mt-12 mb-8">
            <span class="text-[10px] font-medium tracking-[0.2em] uppercase text-white/50">Share</span>

            <a href={`https://twitter.com/intent/tweet?url=${postUrl}&text=${postTitle}`}
               target="_blank" rel="noopener noreferrer"
               class="opacity-40 hover:opacity-100 transition-opacity duration-200" title="Share on X">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                <path fill="white" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622 5.911-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>

            <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${postUrl}`}
               target="_blank" rel="noopener noreferrer"
               class="opacity-40 hover:opacity-100 transition-opacity duration-200" title="Share on LinkedIn">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                <path fill="white" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>

            <a href={`https://www.facebook.com/sharer/sharer.php?u=${postUrl}`}
               target="_blank" rel="noopener noreferrer"
               class="opacity-40 hover:opacity-100 transition-opacity duration-200" title="Share on Facebook">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                <path fill="white" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
            </a>

            <a href="https://instagram.com/criative.net"
               target="_blank" rel="noopener noreferrer"
               class="opacity-40 hover:opacity-100 transition-opacity duration-200" title="Instagram">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                <path fill="white" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </a>

            <a href="https://threads.net/@criative.net"
               target="_blank" rel="noopener noreferrer"
               class="opacity-40 hover:opacity-100 transition-opacity duration-200" title="Threads">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                <path fill="white" d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.474 12.01v-.017c.03-3.579.885-6.43 2.55-8.48C5.85 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 013.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.586-1.308-.883-2.378-.887h-.018c-.852 0-1.99.225-2.74 1.163l-1.608-1.285c1.063-1.37 2.727-2.083 4.357-2.083h.032c3.635.02 5.82 2.253 5.973 6.146.054.009.107.02.161.03.95.195 1.816.594 2.523 1.166.875.7 1.47 1.664 1.75 2.811.716 2.9-.386 5.87-2.794 7.647-1.764 1.309-4.033 2.003-6.78 2.062l-.024.001z"/>
              </svg>
            </a>

            <a href="https://tiktok.com/@criative.net"
               target="_blank" rel="noopener noreferrer"
               class="opacity-40 hover:opacity-100 transition-opacity duration-200" title="TikTok">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
                <path fill="white" d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
              </svg>
            </a>
          </div>
        );
      })()}

      {/* ── Source link CTA ───────────────────── */}
      {sourceLink && (
        <div class="mt-14 pt-8 border-t border-white/[0.07]">
          <a
            href={sourceLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-5 py-3 rounded-xl
                   border border-white/[0.12] bg-white/[0.04]
                   text-sm font-medium text-white/70
                   hover:border-white/25 hover:bg-white/[0.08] hover:text-white
                   transition-all duration-200 group"
          >
            <svg class="w-4 h-4 opacity-60 group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
            </svg>
            Read Original Source
          </a>
        </div>
      )}

    </article>

    <Footer />
  </body>
</html>

<style>
  /* Markdown content styling — manually scoped to avoid Tailwind prose conflicts */
  .prose-content {
    color: rgba(255,255,255,0.65);
    font-size: 0.9375rem;
    line-height: 1.8;
  }
  .prose-content h2 {
    color: rgba(255,255,255,0.92);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 2.5rem 0 1rem;
  }
  .prose-content h3 {
    color: rgba(255,255,255,0.85);
    font-size: 1.05rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }
  .prose-content p {
    margin: 0 0 1.4rem;
  }
  .prose-content a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.2);
    transition: color 0.15s, border-color 0.15s;
  }
  .prose-content a:hover {
    color: rgba(255,255,255,1);
    border-color: rgba(255,255,255,0.5);
  }
  .prose-content strong {
    color: rgba(255,255,255,0.9);
    font-weight: 600;
  }
  .prose-content blockquote {
    border-left: 2px solid rgba(255,255,255,0.15);
    padding: 0.25rem 0 0.25rem 1.25rem;
    margin: 1.5rem 0;
    color: rgba(255,255,255,0.4);
    font-style: italic;
  }
  .prose-content code {
    background: rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.8);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }
  .prose-content pre {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .prose-content pre code {
    background: transparent;
    padding: 0;
  }
  .prose-content hr {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.07);
    margin: 2.5rem 0;
  }
  .prose-content img {
    max-width: 100%;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.07);
    margin: 1.5rem 0;
  }
  .prose-content ul,
  .prose-content ol {
    padding-left: 1.5rem;
    margin: 0 0 1.4rem;
  }
  .prose-content li {
    margin-bottom: 0.4rem;
  }
</style>
