---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'>;
const post = Astro.props;
const { Content } = await render(post);

const { title, description, pubDate, image, sourceLink, source } = post.data;

const SOURCE_LABELS: Record<string, string> = {
  'awwwards':     'Awwwards',
  'google-cloud': 'Google Cloud',
  'feed':         'From the Feed',
};

const sourceLabel = SOURCE_LABELS[source ?? ''] ?? 'Post';

const date = pubDate.toLocaleDateString('en-US', {
  weekday: 'long', year: 'numeric', month: 'long', day: 'numeric',
});
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`${title} — Criative.io`} description={description ?? ''} />
  </head>

  <body class="bg-[#0a0a0a] text-white min-h-screen">
    <Header />

    <article class="max-w-3xl mx-auto px-6 py-12">

      {/* ── Meta row ──────────────────────────── */}
      <div class="flex items-center gap-3 mb-8">
        <a href="/" class="text-white/25 hover:text-white/60 transition-colors text-xs flex items-center gap-1.5 group">
          <svg class="w-3 h-3 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
          </svg>
          Back
        </a>
        <span class="w-px h-3 bg-white/10"></span>
        <span class="text-[10px] font-medium uppercase tracking-widest text-white/30">{sourceLabel}</span>
        <span class="w-px h-3 bg-white/10"></span>
        <time class="text-[10px] text-white/25">{date}</time>
      </div>

      {/* ── Title ─────────────────────────────── */}
      <h1 class="text-2xl md:text-3xl lg:text-4xl font-bold text-white leading-tight tracking-tight mb-6">
        {title}
      </h1>

      {description && (
        <p class="text-white/45 text-base leading-relaxed mb-8 border-b border-white/[0.07] pb-8">
          {description}
        </p>
      )}

      {/* ── Hero image ────────────────────────── */}
      {image && (
        <div class="rounded-xl overflow-hidden border border-white/[0.08] mb-10">
          <img
            src={image}
            alt={title}
            class="w-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>
      )}

      {/* ── Markdown body ─────────────────────── */}
      <div class="prose-content">
        <Content />
      </div>

      {/* ── Source link CTA ───────────────────── */}
      {sourceLink && (
        <div class="mt-14 pt-8 border-t border-white/[0.07]">
          <a
            href={sourceLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-5 py-3 rounded-xl
                   border border-white/[0.12] bg-white/[0.04]
                   text-sm font-medium text-white/70
                   hover:border-white/25 hover:bg-white/[0.08] hover:text-white
                   transition-all duration-200 group"
          >
            <svg class="w-4 h-4 opacity-60 group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
            </svg>
            Read Original Source
          </a>
        </div>
      )}

    </article>

    <Footer />
  </body>
</html>

<style>
  /* Markdown content styling — manually scoped to avoid Tailwind prose conflicts */
  .prose-content {
    color: rgba(255,255,255,0.65);
    font-size: 0.9375rem;
    line-height: 1.8;
  }
  .prose-content h2 {
    color: rgba(255,255,255,0.92);
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 2.5rem 0 1rem;
  }
  .prose-content h3 {
    color: rgba(255,255,255,0.85);
    font-size: 1.05rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }
  .prose-content p {
    margin: 0 0 1.4rem;
  }
  .prose-content a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.2);
    transition: color 0.15s, border-color 0.15s;
  }
  .prose-content a:hover {
    color: rgba(255,255,255,1);
    border-color: rgba(255,255,255,0.5);
  }
  .prose-content strong {
    color: rgba(255,255,255,0.9);
    font-weight: 600;
  }
  .prose-content blockquote {
    border-left: 2px solid rgba(255,255,255,0.15);
    padding: 0.25rem 0 0.25rem 1.25rem;
    margin: 1.5rem 0;
    color: rgba(255,255,255,0.4);
    font-style: italic;
  }
  .prose-content code {
    background: rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.8);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }
  .prose-content pre {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .prose-content pre code {
    background: transparent;
    padding: 0;
  }
  .prose-content hr {
    border: none;
    border-top: 1px solid rgba(255,255,255,0.07);
    margin: 2.5rem 0;
  }
  .prose-content img {
    max-width: 100%;
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.07);
    margin: 1.5rem 0;
  }
  .prose-content ul,
  .prose-content ol {
    padding-left: 1.5rem;
    margin: 0 0 1.4rem;
  }
  .prose-content li {
    margin-bottom: 0.4rem;
  }
</style>
